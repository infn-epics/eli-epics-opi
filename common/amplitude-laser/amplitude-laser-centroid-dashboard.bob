  <widget type="xyplot" version="3.0.0">
    <name>NF_REGEN_Centroid_Plot</name>
    <x>232</x><y>144</y><width>332</width><height>260</height>
    <show_toolbar>true</show_toolbar>
    <x_axis><title>X</title><autoscale>true</autoscale><minimum>-1.0</minimum><maximum>1.0</maximum><show_grid>true</show_grid><visible>true</visible></x_axis>
    <y_axes><y_axis><title>Y</title><autoscale>true</autoscale><minimum>-1.0</minimum><maximum>1.0</maximum><show_grid>true</show_grid><visible>true</visible><color><color red="0" green="0" blue="0"></color></color></y_axis></y_axes>
