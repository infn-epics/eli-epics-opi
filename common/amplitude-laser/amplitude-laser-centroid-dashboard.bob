<?xml version="1.0" encoding="UTF-8"?>
<display version="2.0.0">
  <name>Amplitude Laser Centroid Dashboard</name>
  <macros>
    <PREFIX>$(PREFIX=LEL-LASER)</PREFIX>
  </macros>
  <width>1750</width>
  <height>980</height>
  <background_color>
    <color red="232" green="238" blue="245">
    </color>
  </background_color>
  <grid_step_x>5</grid_step_x>
  <grid_step_y>5</grid_step_y>

  <widget type="rectangle" version="2.0.0">
    <name>HeaderBackground</name>
    <width>1750</width>
    <height>58</height>
    <line_width>0</line_width>
    <background_color>
      <color red="22" green="52" blue="94">
      </color>
    </background_color>
  </widget>
  <widget type="label" version="2.0.0">
    <name>HeaderTitle</name>
    <text>Amplitude Laser Diagnostics</text>
    <x>18</x>
    <y>10</y>
    <width>620</width>
    <height>38</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="24.0">
      </font>
    </font>
    <foreground_color>
      <color red="255" green="255" blue="255">
      </color>
    </foreground_color>
    <transparent>true</transparent>
    <vertical_alignment>1</vertical_alignment>
  </widget>
  <widget type="label" version="2.0.0">
    <name>HeaderPrefix</name>
    <text>PV Prefix: $(PREFIX)</text>
    <x>1410</x>
    <y>18</y>
    <width>320</width>
    <height>24</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="13.0">
      </font>
    </font>
    <foreground_color>
      <color red="196" green="226" blue="255">
      </color>
    </foreground_color>
    <transparent>true</transparent>
    <horizontal_alignment>2</horizontal_alignment>
    <vertical_alignment>1</vertical_alignment>
  </widget>

  <widget type="label" version="2.0.0">
    <name>LegendActual</name>
    <text>Centroid Actual</text>
    <x>18</x>
    <y>66</y>
    <width>130</width>
    <height>22</height>
    <foreground_color>
      <color red="0" green="86" blue="179">
      </color>
    </foreground_color>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0">
      </font>
    </font>
    <transparent>true</transparent>
  </widget>
  <widget type="label" version="2.0.0">
    <name>LegendRef</name>
    <text>User Reference</text>
    <x>155</x>
    <y>66</y>
    <width>130</width>
    <height>22</height>
    <foreground_color>
      <color red="196" green="48" blue="43">
      </color>
    </foreground_color>
    <font>
      <font family="Liberation Sans" style="BOLD" size="11.0">
      </font>
    </font>
    <transparent>true</transparent>
  </widget>

  <!-- NF REGEN -->
  <widget type="rectangle" version="2.0.0">
    <name>NF_REGEN_Card</name>
    <x>18</x>
    <y>95</y>
    <width>560</width>
    <height>425</height>
    <line_width>2</line_width>
    <line_color><color red="77" green="122" blue="168"></color></line_color>
