      <tab>
        <name>Log Vac ILK</name>
        <children>
          <widget type="table" version="2.0.0">
            <name>Table</name>
            <x>78</x>
            <y>62</y>
            <columns>
              <column>
                <name>Time</name>
                <width>250</width>
                <editable>false</editable>
              </column>
              <column>
                <name>Ilk</name>
                <width>250</width>
                <editable>true</editable>
              </column>
            </columns>
            <scripts>
              <script file="EmbeddedPy">
                <text><![CDATA[from org.csstudio.display.builder.runtime.script import PVUtil
from java.time import LocalDateTime
import json

# --- PV memoria ---
history_pv = pvs[3]     # loc://history
last_ruf_pv = pvs[4]    # loc://last_ruf
last_cor_pv = pvs[5]    # loc://last_cor

# --- Leggi storico ---
history_str = PVUtil.getString(history_pv)

try:
    merge = json.loads(history_str) if history_str else []
    if not isinstance(merge, list):
        merge = []
except:
    merge = []

# --- Leggi valori attuali ---
value_ruf = PVUtil.getInt(pvs[0])
value_cor = PVUtil.getInt(pvs[2])
value=value_cor

# --- Leggi ultimi valori salvati ---
last_ruf = PVUtil.getInt(last_ruf_pv)
last_cor = PVUtil.getInt(last_cor_pv)

# --- FLAG cambiamento ---
changed = False

# =======================
# 🔵 RUF
# =======================
value=value_ruf
if value_ruf != last_ruf:

    if value == 0:
	label = "NO RUF ILK"
    if value == 240:
	label = "ILK RUF spare"
    if value == 1:
    	label = 'LEL-VAC-WGC01:IONP02'
    if value == 2:
   	 label = 'LEL-VAC-WGC01:IONP03'
    if value == 4:
    	label = 'LEL-VAC-WGC01:IONP04'
    if value == 8:
    	label = 'LEL-VAC-WCS01:IONP05'
    if value == 16:
	label = 'ILK RUF spare ch1'
    if value == 32:
	 label = 'ILK RUF spare ch2'
    if value == 64:
	label = 'ILK RUF spare ch3'
    if value == 128:
	 label = 'ILK RUF spare ch4'
    if value == 256:
    	label = 'LEL-VAC-WGS02:IONP03'
    if value == 512:
    	label = 'LEL-VAC-WGS02:IONP04'
    if value == 1024:
    	label = 'LEL-VAC-WGS02:IONP05'
    if value == 2048:
    	label = 'LEL-VAC-WGS03:IONP01'
    if value == 4096:
    	label = 'LEL-VAC-WGS03:IONP02'
    if value == 8192:
    	label = 'LEL-VAC-WGS03:IONP03'
    if value == 16384:
    	label = 'LEL-VAC-WGS03:IONP04'
    if value == 32768:
    	label = 'LEL-VAC-WGC01:IONP01'
    if value == 65536:
    	label = 'LEL-VAC-WGS01:IONP01'
    if value == 131072:
    	label = 'LEL-VAC-WGS01:IONP02'
    if value == 262144:
   	 label = 'LEL-VAC-WGS01:IONP03'
    if value == 524288:
    	label = 'LEL-VAC-WGS01:IONP04'
    if value == 1048576:
   	 label = 'LEL-VAC-WGS01:IONP05'
    if value == 2097152:
    	label = 'LEL-VAC-WGS01:IONP06'
    if value == 4194304:
   	 label = 'LEL-VAC-WGS02:IONP01'
    if value == 8388608:
    	label = 'LEL-VAC-WGS02:IONP02'


    time = str(LocalDateTime.now())
    merge.append([time, label])

    last_ruf_pv.write(value_ruf)
    changed = True

# =======================
# 🔵 COR
# =======================
if value_cor != last_cor:

    label_2 = "UNKNOWN"
    if value_cor == 0:
   	 label_2 = 'NO COR ILK '
    if value_cor == 8388608:
    	label_2 = 'ILK COR spare'
    if value_cor == 16777216:
    	label_2 = 'LEL-VAC-IONP01'
    if value_cor == 33554432:
    	label_2 = 'LEL-VAC-IONP02'
    if value_cor == 67108864:
   	 label_2 = 'LEL-VAC-IONP03'
    if value_cor == 134217728:
   	 label_2 = 'LEL-VAC-IONP04'
    if value_cor == 268435456:
   	 label_2 = 'LEL-VAC-IONP05'
    if value_cor == 536870912:
    	label_2 = 'LEL-VAC-IONP06'
    if value_cor == 1073741824:
   	 label_2 = 'LEL-VAC-IONP07'
    if value_cor == 2147483648:
    	label_2 = 'LEL-VAC-IONP08'
    if value_cor == 65536:
    	label_2 = 'LEL-VAC-IONP09'
    if value_cor == 131072:
    	label_2 = 'LEL-VAC-IONP10'
    if value_cor == 262144:
    	label_2 = 'LEL-VAC-IONP11'
    if value_cor == 524288:
   	 label_2 = 'LEL-VAC-IONP12'
    if value_cor == 1048576:
   	 label_2 = 'LEL-VAC-IONP13'
    if value_cor == 2097152:
	label_2 = 'LEL-VAC-IONP14'
    if value_cor == 4194304:
	label_2 = 'LEL-VAC-IONP15'


    time_2 = str(LocalDateTime.now())
    merge.append([time_2, label_2])

    last_cor_pv.write(value_cor)
    changed = True

# =======================
# aggiorna SOLO se cambia
# =======================
if changed:

    # tieni solo ultime 10
    if len(merge) > 10:
        merge = merge[-10:]

    history_pv.write(json.dumps(merge))
    widget.setValue(merge)]]></text>
                <pv_name>RUF-MPS-A-001:ILK:VAC_RUF</pv_name>
                <pv_name trigger="false">loc://merge(0)</pv_name>
                <pv_name>RUF-MPS-A-001:ILK:VAC_COR</pv_name>
                <pv_name trigger="false">loc://memory</pv_name>
                <pv_name trigger="false"> loc://last_ruf</pv_name>
                <pv_name trigger="false"> loc://last_cor</pv_name>
              </script>
            </scripts>
          </widget>
        </children>
      </tab>
